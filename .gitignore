# ---------------------------------------------------------------------------

node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

