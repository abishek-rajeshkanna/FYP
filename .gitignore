# ---------------------------------------------------------------------------
# Python / backend
# ---------------------------------------------------------------------------

# Virtual environments
# NOTE: do NOT add bare `env/` here — `backend/env/` is a source folder.
backend/venv/
backend/env_venv/
venv/
.venv/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# Tensorboard / training artifacts
tensorboard/
ppo_tensorboard/
runs/
*.ckpt
*.pt
*.pth

